# ─── Supabase ────────────────────────────────────────────────────────────────
# Copie estes valores do painel do Supabase:
# Project Settings → API → Project URL / anon public
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública do seu deploy (usado nos redirects de email)
NEXT_PUBLIC_SITE_URL=https://seudominio.vercel.app

# ─── Slug padrão (opcional) ───────────────────────────────────────────────────
# Se quiser um restaurante "padrão" quando nenhum slug está na URL
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=

# ─── Supabase Service Role (NUNCA expor no browser) ──────────────────────────
# Usado apenas em Server Actions / API routes que precisam bypassar o RLS
# Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Pagar.me ────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.pagar.me → Configurações → Chaves de API
# Use sk_test_... em desenvolvimento e sk_live_... em produção
PAGARME_SECRET_KEY=

# Split marketplace (opcional — conta PSP)
# ID do recebedor da plataforma Nenos Food (rp_...)
PAGARME_PLATFORM_RECIPIENT_ID=
# Percentual retido pela plataforma (ex.: 10 = 10%)
PAGARME_PLATFORM_FEE_PERCENT=10
# Expiração do PIX em segundos (padrão: 3600 = 1h)
PAGARME_PIX_EXPIRES_IN=3600

# ─── Nenos Food — variáveis de ambiente ─────────────────────
# Copie para .env.local (desenvolvimento) ou configure na Vercel (produção).
# Referência completa: docs/ENVIRONMENT.md

# ─── Supabase (obrigatório) ─────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role — NUNCA exponha no cliente (server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App (obrigatório) ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=lucianis-di-qualita

# ─── Pagar.me (pagamento online / PIX) ──────────────────────
# Dashboard → Configurações → Chaves de API
PAGARME_SECRET_KEY=

# Split marketplace (opcional)
PAGARME_PLATFORM_RECIPIENT_ID=rp_xxxxxxxx
PAGARME_PLATFORM_FEE_PERCENT=10

# Webhook — URL: https://SEU-DOMINIO/api/payments/pagarme/webhook
PAGARME_WEBHOOK_USER=
PAGARME_WEBHOOK_PASSWORD=

# Expiração do PIX em segundos (padrão: 3600 = 1h)
PAGARME_PIX_EXPIRES_IN=3600

# Mock dev: testa PIX online sem chave real (NUNCA em produção)
PAGARME_DEV_MOCK=true

# Monitoramento opcional (Sentry)
# SENTRY_DSN=https://key@o0.ingest.sentry.io/project-id

# ─── Scripts de banco (terminal only, não commitar) ─────────
# PGPW=sua-senha-postgres
# PROJECT_REF=seu-project-ref

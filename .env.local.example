# ─── Supabase ───────────────────────────────────────────────
# Encontrado em Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chave service_role — NUNCA exponha no cliente. Usada apenas no servidor.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Slug do restaurante principal (operação single-tenant inicial)
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=lucianis-di-qualita

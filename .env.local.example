# ─── Supabase ───────────────────────────────────────────────
# Encontrado em Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chave service_role — NUNCA exponha no cliente. Usada apenas no servidor.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Slug do restaurante principal (operação single-tenant inicial)
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=lucianis-di-qualita

# ─── Pagar.me (pagamento online / PIX) ─────────────────────
# Dashboard Pagar.me > Configurações > Chaves de API
PAGARME_SECRET_KEY=

# Split marketplace (opcional — necessário para repasse automático)
PAGARME_PLATFORM_RECIPIENT_ID=rp_xxxxxxxx
PAGARME_PLATFORM_FEE_PERCENT=10

# Webhook (opcional em dev — configure no painel Pagar.me)
# URL: https://SEU-DOMINIO/api/payments/pagarme/webhook
PAGARME_WEBHOOK_USER=
PAGARME_WEBHOOK_PASSWORD=

# Expiração do PIX em segundos (padrão: 3600 = 1h)
PAGARME_PIX_EXPIRES_IN=3600

# Modo mock: permite testar PIX online sem chave Pagar.me (somente dev)
PAGARME_DEV_MOCK=true
